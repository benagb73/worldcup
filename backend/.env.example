# ============================================================
# World Cup Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Database -----------------------------------------------------------
# Local development: leave Turso blank, the app falls back to a SQLite
# file at LOCAL_DB_PATH.
# Production: set TURSO_URL + TURSO_TOKEN from your Turso dashboard.
TURSO_URL=
TURSO_TOKEN=
LOCAL_DB_PATH=worldcup.db

# --- Security ----------------------------------------------------------
# Shared secret used as the X-Admin-Secret header by the hidden /admin UI.
# Anyone with this string can edit scores, lineups, stats, scoring rules.
# Change it before deploying!
SYNC_SECRET=change-me-in-production

# --- CORS (production only) -------------------------------------------
# Comma-separated list of front-end origins allowed to call the API.
# Local dev: leave blank (allows everything).
# Production: set to your Vercel URL(s), e.g.
#   ALLOWED_ORIGINS=https://worldcup.vercel.app,https://worldcup-ben.vercel.app
ALLOWED_ORIGINS=

# --- Optional legacy API-Football provider (NOT USED) -----------------
# Kept for reference — the project is currently driven by the xlsx seeder
# and admin UI, not the live data provider. Safe to ignore.
# API_FOOTBALL_KEY=
# API_FOOTBALL_HOST=v3.football.api-sports.io
# WC_SEASON=2026
# WC_LEAGUE_ID=1
