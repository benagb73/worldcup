# ============================================================
# World Cup Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# --- Turso (production) ---
# Leave blank to use local SQLite instead
TURSO_URL=libsql://your-database-name.turso.io
TURSO_TOKEN=eyJhbGciOiJFZERTQSJ9...

# --- Local SQLite (development fallback) ---
LOCAL_DB_PATH=worldcup.db

# --- Data provider ---
# Sign up at https://dashboard.api-football.com/
API_FOOTBALL_KEY=your_rapidapi_key_here
API_FOOTBALL_HOST=api-football-v3.p.rapidapi.com
WC_SEASON=2026
WC_LEAGUE_ID=1     # FIFA World Cup league ID on API-Football

# --- Security ---
# Secret header required by POST /api/sync
SYNC_SECRET=change-me-in-production
